# Local npm start/dev configuration.
# Copy this file to .env before running npm run dev or npm start.

MEDIA_ROOT=/path/to/media
PIN_CODE=1234
PORT=3000

SESSION_TTL_MINUTES=720
LOGIN_WINDOW_MINUTES=10
LOGIN_MAX_ATTEMPTS=8

MAX_UPLOAD_FILES=200
MAX_UPLOAD_FILE_MB=250
UPLOAD_TMP_DIR=/tmp/local-media-viewer-uploads
# ALLOWED_ORIGINS=https://media.example.local,http://localhost:5173

# Cache
# Original media files are not copied here; only previews and metadata are stored.
CACHE_DIR=/tmp/local-media-viewer-cache
CACHE_METADATA_PATH=/tmp/local-media-viewer-cache/metadata.json
CACHE_VERSION=1
CACHE_MAX_BYTES=1073741824
CACHE_CLEANUP_INTERVAL_MINUTES=30
METADATA_CACHE_ENABLED=true

# Thumbnails
THUMB_SIZES=240,480,720
THUMB_DEFAULT_SIZE=480
THUMB_FORMAT=webp
THUMB_QUALITY=68
THUMB_EFFORT=4
THUMB_CONCURRENCY=2

# Video previews currently use lightweight placeholders.
# VIDEO_THUMBNAILS is reserved for future real video frame generation.
# VIDEO_THUMBNAILS=false
VIDEO_THUMB_QUALITY=72

# Docker Compose configuration.
# Copy this file to .env before running docker compose.

# Better dont use latest tag
# VERSION=latest

# Host media directory mounted into the container as /media.
MEDIA_HOST_DIR=/path/to/media

PIN_CODE=1234
PORT=3000

SESSION_TTL_MINUTES=720
LOGIN_WINDOW_MINUTES=10
LOGIN_MAX_ATTEMPTS=8

MAX_UPLOAD_FILES=200
MAX_UPLOAD_FILE_MB=250
# Host directory mounted into the container as /uploads-tmp.
UPLOAD_TMP_HOST_DIR=/tmp/local-media-viewer-uploads
# ALLOWED_ORIGINS=https://media.example.local,http://localhost:5173

# Cache
# Host directory or named volume mounted into the container as /cache.
CACHE_HOST_DIR=media-viewer-cache
CACHE_VERSION=1
CACHE_MAX_BYTES=1073741824
CACHE_CLEANUP_INTERVAL_MINUTES=30
METADATA_CACHE_ENABLED=true

# Thumbnails
THUMB_SIZES=240,480,720
THUMB_DEFAULT_SIZE=480
THUMB_FORMAT=webp
THUMB_QUALITY=68
THUMB_EFFORT=4
THUMB_CONCURRENCY=2

# Video previews use a single ffmpeg-extracted frame when available.
VIDEO_THUMBNAILS=true
VIDEO_THUMB_SECONDS=1
# FFMPEG_PATH=ffmpeg
VIDEO_THUMB_QUALITY=72
